#!/bin/bash
# Post-install script for figma-ai-score CLI.
#
# What this script does, in order:
#   - Copies the CLI files + bundled Node + node_modules to
#     ~/Library/Application Support/figma-ai-score/cli/.
#   - Symlinks the launcher to ~/.local/bin/figma-ai-score (always) and,
#     best-effort, /usr/local/bin/figma-ai-score.
#   - Regenerates the `<!-- figma-ai-score -->` block in
#     ~/.claude/CLAUDE.md AND the /ai-score slash command, both from
#     `figma-ai-score integrate` output (cli/integrate.js is the single
#     source of truth).
#
# macOS .pkg postinstall scripts run as root with a minimal PATH. We
# re-exec as the installing user with a login shell to pick up their
# real PATH and avoid root-owned files in their home.

set -e

# ── Figure out who we're installing for ──
INSTALL_USER="${USER:-}"
if [ -z "$INSTALL_USER" ] || [ "$INSTALL_USER" = "root" ]; then
  INSTALL_USER="$(stat -f '%Su' /dev/console 2>/dev/null || true)"
fi
if [ -z "$INSTALL_USER" ] || [ "$INSTALL_USER" = "root" ]; then
  echo "ERROR: could not determine a non-root installing user." >&2
  exit 1
fi
USER_HOME="$(eval echo ~"$INSTALL_USER")"

LOG_DIR="$USER_HOME/Library/Logs"
mkdir -p "$LOG_DIR" 2>/dev/null || true
LOG="$LOG_DIR/figma-ai-score-install.log"
if [ -e "$LOG" ] && [ ! -w "$LOG" ]; then
  LOG="$LOG_DIR/figma-ai-score-install-$(date +%Y%m%d-%H%M%S).log"
fi
exec > >(tee -a "$LOG") 2>&1
echo "=== figma-ai-score install $(date) ==="
echo "Running as: $(id -un) (uid $(id -u))"
echo "Installing for: $INSTALL_USER ($USER_HOME)"

# ── Phase 1: if we're root, re-exec as the installing user ──
if [ "$(id -u)" = "0" ]; then
  if [ -d "$USER_HOME/Library/Application Support/figma-ai-score" ]; then
    echo "Removing root-owned leftovers from previous install attempt ..."
    rm -rf "$USER_HOME/Library/Application Support/figma-ai-score"
  fi

  STAGE="$USER_HOME/Library/Caches/figma-ai-score-pkg"
  rm -rf "$STAGE"
  mkdir -p "$(dirname "$STAGE")"
  cp -R /tmp/figma-ai-score-pkg "$STAGE"
  chown -R "$INSTALL_USER" "$STAGE"
  chown "$INSTALL_USER" "$USER_HOME/Library/Caches" 2>/dev/null || true
  rm -rf /tmp/figma-ai-score-pkg

  echo "Re-executing as $INSTALL_USER ..."
  exec /usr/bin/su - "$INSTALL_USER" -c "FIGMA_AI_SCORE_STAGE='$STAGE' bash '$0'"
fi

# ── Phase 2: running as the installing user with a login shell ──
echo "Phase 2 PATH: $PATH"

STAGE="${FIGMA_AI_SCORE_STAGE:-/tmp/figma-ai-score-pkg}"
APP_SUPPORT="$HOME/Library/Application Support/figma-ai-score"
INSTALL_DIR="$APP_SUPPORT/cli"
NODE_BIN="$INSTALL_DIR/node"
LAUNCHER_SH="$INSTALL_DIR/launcher.sh"
CLI_JS="$INSTALL_DIR/cli.js"

CLAUDE_DIR="$HOME/.claude"
CLAUDE_MD="$CLAUDE_DIR/CLAUDE.md"
COMMANDS_DIR="$CLAUDE_DIR/commands"
SLASH_CMD_MD="$COMMANDS_DIR/ai-score.md"
LEGACY_REVIEW_MD="$COMMANDS_DIR/review.md"
MARKER="<!-- figma-ai-score -->"

USER_LOCAL_BIN="$HOME/.local/bin"
USER_LOCAL_LINK="$USER_LOCAL_BIN/figma-ai-score"
SYS_LOCAL_LINK="/usr/local/bin/figma-ai-score"

# ── 1. Copy CLI files + bundled Node + node_modules ──
# Wipe any prior cli/ first so stale node_modules can't shadow new ones.
# The pkg payload is self-contained — staged dir already includes:
#   - cli.js, bridge.js, integrate.js, package.json (CLI source)
#   - node_modules/ (only `ws`)
#   - node (bundled Node.js binary)
#   - launcher.sh (POSIX shim that execs node + cli.js)
rm -rf "$INSTALL_DIR"
echo "Copying CLI + bundled Node.js to $INSTALL_DIR ..."
mkdir -p "$INSTALL_DIR"
cp -R "$STAGE/cli/." "$INSTALL_DIR/"
chmod +x "$NODE_BIN" "$LAUNCHER_SH" "$CLI_JS"

# ── 2. Symlink the launcher onto PATH ──
# ~/.local/bin is the always-attempted target (no sudo needed). Many shells
# auto-include it on macOS; if not, postinstall surfaces a clear message.
mkdir -p "$USER_LOCAL_BIN"
ln -sf "$LAUNCHER_SH" "$USER_LOCAL_LINK"
echo "Linked: $USER_LOCAL_LINK -> $LAUNCHER_SH"

# /usr/local/bin is best-effort (Homebrew-using machines usually have it
# writable; corp-managed Macs sometimes don't). Don't fail the install if
# this doesn't work — ~/.local/bin already covers us.
if ln -sf "$LAUNCHER_SH" "$SYS_LOCAL_LINK" 2>/dev/null; then
  echo "Linked: $SYS_LOCAL_LINK -> $LAUNCHER_SH"
else
  echo "Note: /usr/local/bin not writable for $INSTALL_USER; skipped (~/.local/bin link is sufficient)."
fi

# Sanity check: can we actually run figma-ai-score? Use the real launcher
# directly so we're not hostage to the user's PATH.
echo "Smoke check: $LAUNCHER_SH --version"
if "$LAUNCHER_SH" --version; then
  echo "CLI launches correctly."
else
  echo "ERROR: figma-ai-score CLI didn't launch. The install is broken." >&2
  exit 1
fi

# Warn if neither symlink ended up on PATH, so the user knows to fix it.
if ! command -v figma-ai-score >/dev/null 2>&1; then
  echo ""
  echo "============================================================"
  echo "WARNING: figma-ai-score is not on your PATH."
  echo "Either /usr/local/bin or ~/.local/bin needs to be on \$PATH."
  echo "Add this to your shell profile (~/.zshrc, ~/.bashrc, etc.):"
  echo "    export PATH=\"\$HOME/.local/bin:\$PATH\""
  echo "Then open a new shell."
  echo "============================================================"
  echo ""
fi

# ── 3. Regenerate ~/.claude/CLAUDE.md figma-ai-score block ──
# Source of truth: cli/integrate.js (--tool claude-md). Replaces between
# markers, not skip — so upgrades pick up updated content.
echo "Updating CLAUDE.md figma-ai-score block ..."
mkdir -p "$CLAUDE_DIR"

CLAUDE_BLOCK="$("$LAUNCHER_SH" integrate --tool claude-md)"
if [ -z "$CLAUDE_BLOCK" ]; then
  echo "ERROR: \`figma-ai-score integrate --tool claude-md\` returned empty output." >&2
  exit 1
fi

if [ -f "$CLAUDE_MD" ] && grep -q "$MARKER" "$CLAUDE_MD"; then
  # Drop everything between the first and last marker pair, then append fresh.
  python3 - "$CLAUDE_MD" "$MARKER" <<'STRIPMARKERS'
import sys, re
path, marker = sys.argv[1], sys.argv[2]
with open(path, 'r') as f:
    src = f.read()
# Remove the entire <!-- figma-ai-score -->...<!-- figma-ai-score --> block
# (and any trailing whitespace/newlines around it so we don't accumulate
# blank lines on repeated upgrades).
pat = re.compile(r'\n*' + re.escape(marker) + r'.*?' + re.escape(marker) + r'\n*', re.DOTALL)
out = pat.sub('\n', src)
with open(path, 'w') as f:
    f.write(out)
STRIPMARKERS
  echo "Removed existing figma-ai-score block from CLAUDE.md."
fi

# Append the fresh block, prefixed by a single blank line.
{
  if [ -s "$CLAUDE_MD" ] && [ "$(tail -c1 "$CLAUDE_MD" 2>/dev/null)" != "" ]; then
    echo ""
  fi
  echo ""
  printf '%s\n' "$CLAUDE_BLOCK"
} >> "$CLAUDE_MD"
echo "Appended fresh figma-ai-score block to CLAUDE.md."

# ── 4. Regenerate /ai-score slash command ──
# Same single-source-of-truth approach — `figma-ai-score integrate --tool claude`
# emits the slash-command body.
echo "Installing /ai-score slash command ..."
mkdir -p "$COMMANDS_DIR"

# Legacy /review cleanup: pre-rename installs left this file. Remove only
# if it looks like ours (contains figma-ai-score wording).
if [ -f "$LEGACY_REVIEW_MD" ] && grep -q "figma-ai-score" "$LEGACY_REVIEW_MD" 2>/dev/null; then
  rm -f "$LEGACY_REVIEW_MD" && echo "Removed legacy ~/.claude/commands/review.md."
fi

"$LAUNCHER_SH" integrate --tool claude > "$SLASH_CMD_MD"
if [ ! -s "$SLASH_CMD_MD" ]; then
  echo "ERROR: failed to write $SLASH_CMD_MD." >&2
  exit 1
fi
echo "Wrote /ai-score slash command."

# ── 5. Clean up staged payload ──
rm -rf "$STAGE"

echo ""
echo "=== figma-ai-score install complete ==="
echo ""
echo "Next steps:"
echo "  1. Open the AI Programmability Score plugin in Figma."
echo "  2. In your AI coding tool, say \"connect to ai score\" to verify,"
echo "     or \"review my design\" / \`/ai-score\` to start."
echo ""
echo "If your AI tool isn't Claude Code (e.g., Cursor, OpenAI Codex CLI,"
echo "Gemini CLI): run \`figma-ai-score integrate\` and follow the printed"
echo "instructions to set up integration for your tool."
