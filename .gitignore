# Dependencies
node_modules/

# macOS
.DS_Store

# Logs
*.log
npm-debug.log*

# Editor / IDE
.vscode/
.idea/
*.swp

# Build artifacts (the .pkg is generated by installer/build-pkg.sh)
*.pkg

# Installer build cache (Node.js tarball downloaded once, reused across builds)
installer/.cache/

# Installer payload is a build artifact — regenerated on every pkg build.
installer/payload/

# Env / local config
.env
.env.local

# Claude Code personal settings — but keep shared slash commands (.claude/commands/).
.claude/settings.local.json
.claude/settings.json

# Per-user AI-tool integration files — regenerated by
# `figma-ai-score integrate --tool <foo>`. Codex / Gemini may drop these in
# the working directory during a fresh install; they aren't repo assets.
/AGENTS.md
/GEMINI.md
/.cursor/
